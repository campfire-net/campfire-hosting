                    },
                    {
                      "name": "CF_DOMAIN",
                      "value": "[parameters('cfDomain')]"
                    }
                  ],
                  "minTlsVersion": "1.2",
                  "http20Enabled": true,
                  "use32BitWorkerProcess": false
                }
              },
              "dependsOn": [
