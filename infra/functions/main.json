{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "6962731700075064928"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "domainName": {
      "type": "string",
      "defaultValue": "mcp.getcampfire.dev",
      "metadata": {
        "description": "Custom domain to bind to the Function App (e.g. mcp.getcampfire.dev)."
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault holding CF_SESSION_TOKEN secret."
      }
    },
    "cfDomain": {
      "type": "string",
      "defaultValue": "mcp.getcampfire.dev",
      "metadata": {
        "description": "CF_DOMAIN env var value passed to the Function App."
      }
    },
    "createCustomDomain": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Whether to create the custom domain binding. Set false on first deploy until DNS CNAME is in place."
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[take(uniqueString(resourceGroup().id), 6)]",
    "appName": "[format('func-campfire-{0}', variables('uniqueSuffix'))]",
    "storageAccountName": "[format('stcampfire{0}', variables('uniqueSuffix'))]",
    "hostingPlanName": "[format('plan-campfire-{0}', variables('uniqueSuffix'))]",
    "appInsightsName": "[format('appi-campfire-{0}', variables('uniqueSuffix'))]",
    "logAnalyticsName": "[format('log-campfire-{0}', variables('uniqueSuffix'))]",
    "tags": {
      "project": "campfire-hosting",
      "environment": "production",
      "domain": "[parameters('domainName')]"
    }
  },
