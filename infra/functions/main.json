              "type": "string",
              "metadata": {
                "description": "Table Storage endpoint."
              },
              "value": "[reference(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-01-01').primaryEndpoints.table]"
            }
          }
        }
      }
    },
    {
